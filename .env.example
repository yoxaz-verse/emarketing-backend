# PORT=3004
# JWT_SECRET=replace-with-at-least-32-random-bytes
# INTERNAL_SERVICE_SECRET=replace-with-a-dedicated-service-secret
# BOOTSTRAP_SECRET=remove-after-the-first-admin-is-created
# OBAOL_WEBHOOK_SECRET=replace-with-a-webhook-signing-secret
# INQUIRY_WEBHOOK_SECRET=replace-with-a-separate-inquiry-signing-secret
# VOICE_ENGINE_URL=http://voice-engine:3004
# VOICE_ENGINE_SECRET=must-match-the-voice-engine
# REQUEST_BODY_LIMIT=1mb


# # Validation queue mode: legacy | bullmq
# EMAIL_VALIDATION_QUEUE_MODE=legacy
# EMAIL_VALIDATION_BULLMQ_FALLBACK_TO_LEGACY=true
# EMAIL_VALIDATION_STALE_MINUTES=10
# EMAIL_VALIDATION_PER_LEAD_TIMEOUT_MS=25000
# EMAIL_VALIDATION_DNS_TIMEOUT_MS=5000
# EMAIL_VALIDATION_CACHE_ENABLED=true
# EMAIL_VALIDATION_CACHE_OP_TIMEOUT_MS=800
# EMAIL_VALIDATION_CACHE_BREAKER_THRESHOLD=3
# EMAIL_VALIDATION_CACHE_BREAKER_COOLDOWN_MS=30000

# # Needed only for bullmq mode
# REDIS_URL=redis://srv-captain--<redis-app-name>:6379
# EMAIL_VALIDATION_QUEUE_CONCURRENCY=10

# # Optional
# SEQUENCE_RUNNER_ENABLED=true
# SEQUENCE_RUNNER_INTERVAL_MS=5000

# Reply capture (MXroute / IMAP)
# ENABLE_REPLY_CAPTURE_IMAP=true
# REPLY_CAPTURE_POLL_INTERVAL_MS=90000
# REPLY_CAPTURE_STALE_MINUTES=5
# REPLY_CAPTURE_INCLUDE_SPAM=false
# REPLY_CAPTURE_IMAP_PORT=993
# REPLY_CAPTURE_IMAP_SECURE=true
# REPLY_CAPTURE_IMAP_HOST=chocobo.mxrouting.net
# REPLY_CAPTURE_FORCE_IMAP_HOST=false
# REPLY_CAPTURE_BACKFILL_ENABLED=true
# REPLY_CAPTURE_BACKFILL_DAYS=7

# Required for agent integration secret encryption
# AGENT_SECRET_KEY=replace-with-a-strong-secret

# Required for social integration secret encryption (64 hex chars)
# SOCIAL_INTEGRATION_SECRET_KEY=replace-with-a-strong-64-hex-secret

# LinkedIn OAuth (v1)
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# LINKEDIN_REDIRECT_URI=https://emarketing-backend.infra.obaol.com/social/oauth2-credential/callback
# LINKEDIN_SCOPES=w_member_social r_liteprofile
# LINKEDIN_API_VERSION=202504
# SOCIAL_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/dashboard/social-connectors

# Meta OAuth (v1)
# META_REDIRECT_URI=https://emarketing-backend.infra.obaol.com/api/auth/meta/callback
